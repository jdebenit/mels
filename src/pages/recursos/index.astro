---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const allEntries = await getCollection("recursos");
const entries = allEntries.filter((entry) => !entry.data.hidden);
---

<Layout title="MELS // RECURSOS">
    <div class="content-container">
        <h1>BIBLIOTECA DE RECURSOS</h1>
        <div class="divider"></div>

        <div class="entries-grid">
            {entries.length === 0 && <p>ESTACIÓN DE DESCARGA VACÍA.</p>}
            {
                entries.map((entry) => (
                    <a
                        href={`/recursos/${entry.id.replace(/\.md$/, "")}`}
                        class="entry-card"
                    >
                        <div class="card-header">
                            <span class="classification">
                                {entry.data.clasificacion || "ACCESO LIBRE"}
                            </span>
                        </div>
                        <h2>{entry.data.title}</h2>
                        <p class="category">
                            {entry.data.categoria || "RECURSO"}
                        </p>
                        <div class="card-footer">
                            <span>ACCEDER</span>
                        </div>
                    </a>
                ))
            }
        </div>
    </div>

    <style>
        .content-container {
            max-width: 900px;
            margin: 100px auto 0;
            padding: 2rem;
            color: #ccc;
        }
        h1 {
            color: var(--color-accent);
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 1rem;
        }
        .divider {
            height: 2px;
            background: var(--color-accent);
            width: 100%;
            margin-bottom: 3rem;
            box-shadow: 0 0 10px var(--color-accent);
        }
        .entries-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
            gap: 2rem;
        }
        .entry-card {
            background: rgba(20, 20, 20, 0.8);
            border: 1px solid var(--color-accent);
            padding: 1.5rem;
            text-decoration: none;
            color: inherit;
            transition: all 0.3s ease;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }
        .entry-card:hover {
            background: rgba(0, 255, 65, 0.1);
            transform: translateY(-5px);
            box-shadow: 0 5px 15px rgba(0, 255, 65, 0.2);
        }
        .card-header {
            font-size: 0.7rem;
            font-family: monospace;
            color: var(--color-accent);
            margin-bottom: 0.5rem;
        }
        h2 {
            color: #fff;
            margin: 0;
            font-size: 1.2rem;
            text-transform: uppercase;
        }
        .category {
            font-size: 0.8rem;
            color: var(--color-secondary);
            margin: 0;
            opacity: 0.8;
            font-family: monospace;
        }
        .card-footer {
            margin-top: auto;
            font-size: 0.7rem;
            text-align: right;
            color: var(--color-accent);
            font-weight: bold;
        }
    </style>
</Layout>
